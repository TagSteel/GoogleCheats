{
  "manifest_version": 3,
  "name": "Google Cheats",
  "short_name": "GCheats",
  "author": ["TagSteel", "MythUp"],
  "version": "1.0.0",
  "description": "Analyse les formulaires et l'IA propose des réponses.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": ["https://*.forms.gle/*", "https://generativelanguage.googleapis.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "default_title": "Google Cheats - Gemini",
  "content_scripts": [
    {
      "matches": ["https://*.forms.gle/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
